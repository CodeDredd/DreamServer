    {
      "parameters": {
        "jsCode": "// Pick the first asset_type that produced a candidate.\n// Sequential chain guarantees both 'Next candidate' nodes have\n// run by the time we get here.\nconst stock  = $('Next candidate (stocks)').first()?.json?.next || null;\nconst crypto = $('Next candidate (crypto)').first()?.json?.next || null;\nlet symbol = null, assetType = null;\nif (stock)       { symbol = stock;  assetType = 'stock';  }\nelse if (crypto) { symbol = crypto; assetType = 'crypto'; }\nif (!symbol) {\n  return [{ json: { skip: true, reason: 'no stale candidate' } }];\n}\nreturn [{ json: { skip: false, symbol, asset_type: assetType, days: 180 } }];"
      },
