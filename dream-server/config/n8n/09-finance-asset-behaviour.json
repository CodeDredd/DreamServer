      "id": "get_news",
      "name": "GET 6mo news",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1960,
        320
      ]
    },
    {
      "parameters": {
        "jsCode": "// Build a compact LLM payload. We deliberately:\n//   * only send the *biggest* daily moves (top 8) \u2014 the LLM is\n//     asked to *explain* them, not invent moves;\n//   * trim news headlines (title + ts + source + sentiment +\n//     news_id) \u2014 no body, keeps prompt under ~6k tokens;\n//   * include first/last/min/max stats so the LLM can quote them\n//     verbatim instead of computing (which is hallucination-prone).\nconst pick   = $node['Pick candidate'].json;\nconst prices = $node['GET 6mo prices'].json;\nconst news   = $node['GET 6mo news'].json;\nconst priceErr = prices?.rows === undefined;\nconst newsErr  = news?.rows  === undefined;\nif (priceErr || !prices.rows.length) {\n  return [{ json: { fatal: true, reason: 'no price history', symbol: pick.symbol } }];\n}\nconst trimmedNews = (news?.rows || []).map(n => ({\n  id: n.id,\n  ts: n.ts,\n  source: n.source,\n  sentiment: n.sentiment,\n  urgency: n.urgency,\n  title: (n.title || '').slice(0, 180),\n})).slice(0, 80);\nreturn [{ json: {\n  symbol: pick.symbol,\n  asset_type: pick.asset_type,\n  days: pick.days,\n  period_start: prices.rows[0].ts,\n  period_end:   prices.rows[prices.rows.length - 1].ts,\n  stats: prices.stats,\n  biggest_moves: prices.biggest,\n  news: trimmedNews,\n} }];"
      },
      "id": "build_payload",
      "name": "Build LLM payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2200,
        320
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "leftValue": "={{ $json.fatal }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "guard_fatal",
      "name": "Has data?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        2440,
        320
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://litellm:4000/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.LITELLM_KEY || $env.LITELLM_API_KEY}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'default', temperature: 0.1, max_tokens: 900, response_format: { type: 'json_object' }, messages: [ { role: 'system', content: 'You are a careful equity / crypto analyst. You ONLY use data the user gives you. Never invent prices, dates, news items, or news IDs. If the news list does not justify a price move, say so. Output STRICT JSON ONLY with this exact shape: {\"summary\": string<=400, \"keywords\": string[]<=12, \"drivers\": [ { \"date\": \"YYYY-MM-DD\", \"move_pct\": number, \"reason\": string<=200, \"news_ids\": (string|number)[] } ]<=8, \"confidence\": number_in_[0,1] }. Every news_id MUST come from the provided news list. Every date MUST come from biggest_moves. If you cannot explain a move from the news, set its reason to \"unexplained from supplied news\" and news_ids to []. Never wrap in markdown.' }, { role: 'user', content: 'Asset: ' + $json.symbol + ' (' + $json.asset_type + ').\\nWindow: ' + $json.period_start + ' to ' + $json.period_end + ' (' + $json.days + ' days).\\nStats: ' + JSON.stringify($json.stats) + '\\nBiggest daily moves (you may only reference these dates as drivers): ' + JSON.stringify($json.biggest_moves) + '\\nNews items (id, ts, source, sentiment, urgency, title):\\n' + JSON.stringify($json.news) + '\\nReturn the JSON object now.' } ] }) }}",
        "options": {
          "timeout": 240000,
          "response": {
            "response": {
              "neverError": true,
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "llm_draft",
      "name": "qwen3.6 \u2014 draft analysis",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2680,
        320
      ]
    },
    {
      "parameters": {
        "jsCode": "// Parse + validate the LLM draft. This is the anti-hallucination\n// gate the user explicitly asked for. We reject any driver that\n// references a date or news_id NOT present in the input payload.\nconst llm  = $items()[0].json;\nconst src  = $node['Build LLM payload'].json;\nlet draft  = null;\nlet rawTxt = '';\ntry {\n  const choice = llm?.choices?.[0]?.message?.content || '';\n  rawTxt = String(choice).trim();\n  // Strip ``` fences if the model added them.\n  const m = rawTxt.match(/\\{[\\s\\S]*\\}/);\n  draft = JSON.parse(m ? m[0] : rawTxt);\n} catch (e) {\n  return [{ json: { reject: true, reason: 'invalid JSON from LLM', raw: rawTxt.slice(0, 800) } }];\n}\nif (!draft || typeof draft !== 'object') {\n  return [{ json: { reject: true, reason: 'LLM returned non-object', raw: rawTxt.slice(0, 800) } }];\n}\nconst allowedIds   = new Set((src.news || []).map(n => String(n.id)));\nconst allowedDates = new Set((src.biggest_moves || []).map(m => (m.date || '').slice(0, 10)));\nconst drivers = Array.isArray(draft.drivers) ? draft.drivers : [];\nconst contradictions = [];\nconst cleanedDrivers = [];\nfor (const d of drivers.slice(0, 12)) {\n  const dt = String(d.date || '').slice(0, 10);\n  if (dt && !allowedDates.has(dt)) {\n    contradictions.push('driver date ' + dt + ' is not in biggest_moves');\n    continue;\n  }\n  const ids = Array.isArray(d.news_ids) ? d.news_ids : [];\n  const cleanIds = ids.filter(id => allowedIds.has(String(id)));\n  if (ids.length > cleanIds.length) {\n    contradictions.push('driver ' + dt + ' referenced ' + (ids.length - cleanIds.length) + ' unknown news_id(s)');\n  }\n  cleanedDrivers.push({\n    date: dt,\n    move_pct: Number(d.move_pct ?? 0),\n    reason: String(d.reason || '').slice(0, 240),\n    news_ids: cleanIds,\n  });\n}\nconst keywords = Array.isArray(draft.keywords) ? draft.keywords.map(k => String(k).slice(0, 32)).slice(0, 12) : [];\nconst summary  = String(draft.summary || '').slice(0, 600);\n// Confidence penalty for contradictions.\nlet conf = Math.max(0, Math.min(1, Number(draft.confidence ?? 0)));\nif (contradictions.length) conf = Math.max(0, conf - 0.15 * contradictions.length);\nconst allNewsIds = Array.from(new Set(cleanedDrivers.flatMap(d => d.news_ids)));\nreturn [{ json: {\n  reject: false,\n  symbol: src.symbol,\n  asset_type: src.asset_type,\n  period_start: src.period_start,\n  period_end:   src.period_end,\n  summary,\n  keywords,\n  drivers: cleanedDrivers,\n  news_ids: allNewsIds,\n  confidence: conf,\n  contradictions: contradictions.length ? contradictions.join('; ') : null,\n  prompt_hash_input: { symbol: src.symbol, period_start: src.period_start, period_end: src.period_end, biggest: src.biggest_moves },\n  raw_response: rawTxt.slice(0, 4000),\n} }];"
      },
