    {
      "parameters": {
        "method": "GET",
        "url": "=http://finance-guru-api:8098/history/news",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "symbol",
              "value": "={{ $('Pick candidate').item.json.symbol }}"
            },
            {
              "name": "days",
              "value": "={{ $('Pick candidate').item.json.days }}"
            },
            {
              "name": "limit",
              "value": "150"
            }
          ]
        },
