      "id": "next_candidate_crypto",
      "name": "Next candidate (crypto)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        960,
        520
      ]
    },
    {
      "parameters": {
        "jsCode": "// Phase A.2: emit ONE n8n item per stale symbol so every downstream\n// node (GET prices, GET news, Build LLM payload, qwen3.6, Verifier,\n// Store analysis, Report OK/error) runs per-item naturally instead\n// of being clamped to first(). Paired-item linkage is preserved by\n// n8n through the chain, so $('Pick candidate').item.json in the\n// downstream Code/HTTP nodes returns the matching pick for the row\n// being processed.\n//\n// Effective throughput per cron tick:\n//   stocks (limit=3) + crypto (limit=2) = up to 5 symbols/run\n//   cron */2 min                          = up to 150 symbols/h\n// (Phase A was: 1 symbol/run * */2 = 30/h \u2014 5x improvement.)\n//\n// Skip-fallback: if both batches are empty we emit a single skip item\n// so 'Report skipped' has something to consume.\nconst stockBatch  = $('Next candidate (stocks)').first()?.json?.next || [];\nconst cryptoBatch = $('Next candidate (crypto)').first()?.json?.next || [];\nconst items = [];\nfor (const s of stockBatch) {\n  items.push({ json: { skip: false, symbol: s, asset_type: 'stock',  days: 180,\n                       batch_index: items.length } });\n}\nfor (const s of cryptoBatch) {\n  items.push({ json: { skip: false, symbol: s, asset_type: 'crypto', days: 180,\n                       batch_index: items.length } });\n}\nif (!items.length) {\n  return [{ json: { skip: true, reason: 'no stale candidate' } }];\n}\nreturn items;"
      },
      "id": "pick",
      "name": "Pick candidate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1240,
        420
      ]
    },
    {
      "parameters": {
        "conditions": {
