    {
      "parameters": {
        "jsCode": "// Combine stock + crypto universes after both GET calls completed.\n// Uses $('node').first() because the workflow is now sequential \u2014\n// no real Merge node needed, both universes are already on the\n// execution trace by the time this Code node runs.\nconst stocks = $('GET universe (stocks)').first().json || {};\nconst crypto = $('GET universe (crypto)').first().json || {};\nreturn [{ json: { universes: [\n  { symbols: (stocks.symbols || []).slice(0, 200), asset_type: 'stock' },\n  { symbols: (crypto.symbols || []).slice(0, 200), asset_type: 'crypto' }\n]}}];"
      },
