        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ asset_type: 'stock', stale_after_hours: 168, limit: 3, universe: $('Merge universe').first().json.universes[0].symbols }) }}",
