    {
      "parameters": {
        "method": "GET",
        "url": "http://finance-guru-api:8098/assets/movers",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "window",
              "value": "1h"
            },
            {
              "name": "min_pct",
              "value": "3"
            },
            {
              "name": "limit",
              "value": "5"
            },
            {
              "name": "dedupe",
              "value": "true"
            },
            {
              "name": "bucket_minutes",
              "value": "60"
            }
          ]
        },
