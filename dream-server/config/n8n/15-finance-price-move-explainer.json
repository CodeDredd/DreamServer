      "parameters": {
        "method": "GET",
        "url": "=http://finance-guru-api:8098/history/news",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "symbol",
              "value": "={{ $json.mover.symbol }}"
            },
            {
              "name": "hours",
              "value": "4"
            },
            {
              "name": "limit",
              "value": "20"
            }
          ]
