      "id": "get_news",
      "name": "GET news (per mover, 4h)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1160,
        220
      ]
    },
    {
      "parameters": {
        "jsCode": "// Stitch the per-mover news payload back onto the mover so the LLM has\n// both the price-move stats and the headline context in one prompt.\nconst mover    = $('Split movers').item.json.mover;\nconst bucket   = $('Split movers').item.json.bucket_ts;\nconst theme    = $('Split movers').item.json.theme;\nconst newsResp = $json || {};\nconst headlines = Array.isArray(newsResp.rows) ? newsResp.rows : [];\n\n// Trim headlines tight: title + sentiment + urgency + ts only.\nconst items = headlines.slice(0, 12).map(r => ({\n  id:        r.id,\n  ts:        r.ts,\n  source:    r.source,\n  sentiment: r.sentiment,\n  urgency:   r.urgency,\n  title:     String(r.title || '').slice(0, 200),\n}));\n\nreturn [{ json: {\n  mover,\n  bucket_ts: bucket,\n  theme,\n  brief_items: items,\n  has_news: items.length > 0,\n} }];"
      },
      "id": "build_brief",
      "name": "Build per-mover brief",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1400,
        220
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://litellm:4000/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.LITELLM_KEY || $env.LITELLM_API_KEY}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'default', temperature: 0.1, max_tokens: 800, response_format: { type: 'json_object' }, messages: [ { role: 'system', content: 'You explain WHY a single asset moved this much in the last hour, using ONLY the supplied headlines. Output STRICT JSON: { \"mechanism\": string<=180, \"drivers\": string[]<=5, \"regime\": one_of(\"news_driven\",\"earnings\",\"macro\",\"sector_rotation\",\"liquidity\",\"sympathy\",\"whale\",\"unexplained\"), \"confidence\": number_in_[0,1], \"evidence_ids\": (string|number)[]<=6, \"summary\": string<=240 }. Rules: (1) evidence_ids MUST come from the supplied headlines and MUST be the `id` field, not the title. (2) If there are NO headlines OR none plausibly explain the move, set regime=\"unexplained\", confidence<=0.2, evidence_ids=[]. (3) drivers are short noun phrases (\"Q3 beat\",\"oil shock\",\"BTC sympathy\"). (4) mechanism is one sentence: cause -> effect. (5) No markdown, no commentary outside the JSON object.' }, { role: 'user', content: 'Mover: ' + JSON.stringify($json.mover) + '\\nHeadlines (last 4h, this symbol): ' + JSON.stringify($json.brief_items) + '\\nReturn ONLY the JSON object now.' } ] }) }}",
        "options": {
          "timeout": 120000,
          "response": {
            "response": {
              "neverError": true,
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "llm_explain",
      "name": "default \u2014 explain move",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1640,
        220
      ]
    },
    {
      "parameters": {
        "jsCode": "// Verifier: parse, enforce evidence_ids \u2286 input, route into one of two\n// sinks based on regime + confidence.\n//   * explained (regime != 'unexplained' AND confidence >= 0.4 AND >=1\n//     verified evidence_id)        \u2192 POST /rag/relation\n//   * unexplained                  \u2192 POST /rag/strategy-lesson with\n//     outcome=note, keywords=[unexplained_move, <SYM>] so the\n//     genesis loop can later build a sympathy/whale strategy.\nconst brief    = $('Build per-mover brief').item.json;\nconst mover    = brief.mover;\nconst theme    = brief.theme;\nconst evIds    = new Set((brief.brief_items || []).map(it => String(it.id)));\nconst llmResp  = $json;\n\nlet raw = '';\nlet parsed = null;\ntry {\n  raw = String(llmResp?.choices?.[0]?.message?.content || '').trim();\n  const m = raw.match(/\\{[\\s\\S]*\\}/);\n  parsed = JSON.parse(m ? m[0] : raw);\n} catch (e) {\n  return [{ json: { route: 'reject', reason: 'invalid JSON from LLM', symbol: mover.symbol, raw: raw.slice(0, 400) } }];\n}\n\nconst mechanism = String(parsed.mechanism || '').slice(0, 180);\nconst summary   = String(parsed.summary   || '').slice(0, 240);\nconst regime    = String(parsed.regime    || 'unexplained').toLowerCase();\nconst conf      = Number(parsed.confidence);\nconst confOk    = (conf >= 0 && conf <= 1);\nconst drivers   = (Array.isArray(parsed.drivers) ? parsed.drivers : [])\n                    .map(s => String(s).trim()).filter(Boolean).slice(0, 5);\nconst evidence  = (Array.isArray(parsed.evidence_ids) ? parsed.evidence_ids : [])\n                    .map(x => String(x)).filter(x => evIds.has(x)).slice(0, 6);\n\nif (!confOk) {\n  return [{ json: { route: 'reject', reason: 'confidence missing/out-of-range', symbol: mover.symbol, raw: raw.slice(0, 400) } }];\n}\n\nconst isExplained = (regime !== 'unexplained') && (conf >= 0.4) && (evidence.length >= 1);\n\nif (isExplained) {\n  // Build the /rag/relation payload.\n  const movePct  = mover.return_pct;\n  const dirText  = movePct >= 0 ? 'rallied' : 'fell';\n  const symText  = `${mover.symbol} ${dirText} ${Math.abs(movePct).toFixed(2)}% in 1h`;\n  return [{ json: {\n    route: 'relation',\n    symbol: mover.symbol,\n    payload: {\n      theme,\n      mechanism: mechanism || null,\n      summary: summary ? `${symText}. ${summary}` : symText,\n      entities: drivers,\n      sectors: [],\n      symbols: [mover.symbol],\n      evidence_ids: evidence,\n      confidence: conf,\n      model: 'default',\n    },\n  } }];\n}\n\n// Unexplained / weak \u2014 emit a strategy-lesson so the genesis loop can\n// pick up the pattern (e.g. sympathy moves with no news).\nconst lessonText = `Unexplained 1h move on ${mover.symbol}: `\n  + `${mover.return_pct.toFixed(2)}% (volume ratio ${mover.volume_ratio ?? 'n/a'}). `\n  + `LLM regime=${regime}, confidence=${conf.toFixed(2)}. `\n  + (mechanism || 'No mechanism produced.') + ' '\n  + `Headlines seen: ${ (brief.brief_items || []).length }.`;\nreturn [{ json: {\n  route: 'lesson',\n  symbol: mover.symbol,\n  payload: {\n    strategy: 'price_move_explainer',\n    outcome: 'note',\n    pnl_pct: null,\n    lesson: lessonText.slice(0, 4000),\n    keywords: ['unexplained_move', mover.symbol.toLowerCase(),\n               (mover.asset_type || 'unknown').toLowerCase(), regime],\n    extra: {\n      symbol: mover.symbol,\n      return_pct: mover.return_pct,\n      volume_ratio: mover.volume_ratio,\n      regime,\n      confidence: conf,\n      bucket_ts: brief.bucket_ts,\n      headline_count: (brief.brief_items || []).length,\n    },\n  },\n} }];"
      },
