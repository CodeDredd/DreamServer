          "timeout": 10000,
          "response": {
            "response": {
              "neverError": true,
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "get_movers",
      "name": "GET /assets/movers (1h, \u22653%)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        440,
        320
      ]
    },
    {
      "parameters": {
        "jsCode": "// Split the movers response into one item per mover (so each gets its\n// own /history/news fetch + LLM call). If no movers, emit a single\n// skip-item so we can report it to /enrichment/run downstream.\nconst resp = $json || {};\nconst movers = Array.isArray(resp.movers) ? resp.movers : [];\nif (!movers.length) {\n  return [{ json: { skip: true, reason: (resp.skipped_dedup\n    ? `no fresh movers (dedup hid ${resp.skipped_dedup})`\n    : `no movers above ${resp.min_pct}% in ${resp.window}`) } }];\n}\nconst out = [];\nfor (const m of movers) {\n  // Bucket the mover into a 60-min window starting at the latest tick.\n  // This gives every explainer call a stable theme suffix so dedup works.\n  let bucket = 0;\n  try {\n    bucket = Math.floor(new Date(m.latest_ts).getTime() / 1000 / 3600) * 3600;\n  } catch (e) { /* keep 0 */ }\n  out.push({ json: {\n    skip: false,\n    mover: m,\n    bucket_ts: bucket,\n    theme: `price_move:${m.symbol}:${bucket}`,\n  } });\n}\nreturn out;"
      },
      "id": "split_movers",
      "name": "Split movers",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        680,
        320
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "leftValue": "={{ $json.skip }}",
              "rightValue": false,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "guard_movers",
