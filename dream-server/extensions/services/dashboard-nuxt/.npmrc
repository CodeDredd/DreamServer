# pnpm-Konfiguration für den Dashboard-NG-Service.
# Halo Strix baut das Image über docker; die folgenden Flags sind
# ausschließlich für lokale Dev-Installs / CI relevant.

# Strikteres peer-Handling abschalten — Nuxt-UI v3 + Pinia-ORM ziehen
# noch ein paar legacy-peer-Bereiche; dieselbe Praxis nutzen die anderen
# Nuxt-/Vue-Packages dieses Repos.
strict-peer-dependencies=false
auto-install-peers=true
shamefully-hoist=true

# Reproduzierbare Installs — pnpm <=10 verlangt --frozen-lockfile in CI.
# Dev-Installs ergänzen explizit `--no-frozen-lockfile`.

