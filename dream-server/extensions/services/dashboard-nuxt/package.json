{
  "name": "dream-dashboard-nuxt",
  "version": "0.1.0",
  "private": true,
  "description": "Dream Server Dashboard NG — Nuxt 4 / Nuxt UI v3 reimplementation (parallel to React variant)",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "nuxt dev --host 0.0.0.0 --port 3011",
    "build": "nuxt build",
    "build:csp": "node scripts/csp-hash.mjs --verbose",
    "generate": "nuxt generate",
    "preview": "node .output/server/index.mjs",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nuxt/ui": "^4.0.0",
    "@nuxtjs/i18n": "^9.0.0",
    "@pinia/nuxt": "^0.11.0",
    "@pinia-orm/nuxt": "2.0.0-alpha.2",
    "@vite-pwa/nuxt": "^0.10.0",
    "@vueuse/integrations": "^13.0.0",
    "@vueuse/math": "^13.0.0",
    "@vueuse/motion": "^2.2.0",
    "@vueuse/nuxt": "^13.0.0",
    "gsap": "^3.12.7",
    "nuxt": "^4.0.0",
    "pinia": "^3.0.0",
    "pinia-orm": "2.0.0-alpha.2",
    "pinia-plugin-persistedstate": "^4.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@nuxt/eslint": "^0.7.0",
    "@nuxt/test-utils": "^3.15.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.0.0",
    "happy-dom": "^15.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.0",
    "vue-tsc": "^2.1.0"
  }
}

